rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'partnumber56@gmail.com' ||
        request.auth.uid == 'NqZwqd7glkdehH3Jnvqh8HR5Dku2' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'sku', 'stock', 'price']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 400 &&
             data.sku is string && data.sku.size() > 0 && data.sku.size() <= 100 &&
             data.stock is number &&
             data.price is number && data.price >= 0 &&
             (data.get('brand', '') is string) &&
             (data.get('supplier', '') is string) &&
             (data.get('category', '') is string) &&
             (data.get('description', '') is string);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'status', 'totalAmount', 'createdAt', 'creatorId']) &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.status in ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled', 'Request'] &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.creatorId == request.auth.uid &&
             (data.get('totalProfit', 0) is number) &&
             (data.get('carModel', '') is string) &&
             (data.get('vin', '') is string) &&
             (request.method == 'create' ? data.createdAt == request.time : true);
    }

    function isValidOrderItem(data) {
      return data.keys().hasAll(['partNumber', 'productName', 'quantity', 'status']) &&
             data.partNumber is string &&
             data.productName is string &&
             (data.get('brand', '') is string) &&
             (data.get('supplier', '') is string) &&
             (data.get('deliveryTime', '') is string) &&
             data.quantity is number && data.quantity > 0 &&
             (data.get('costPrice', 0) is number || data.get('costPrice', '') == '') &&
             (data.get('sellingPrice', 0) is number || data.get('sellingPrice', '') == '') &&
             data.status in ['Pending', 'Ordered', 'Available', 'Out of Stock', 'Picked', 'Packed', 'Issued'];
    }

    match /{path=**}/items/{itemId} {
      allow read: if isSignedIn();
    }

    function isValidClient(data) {
      return data.keys().hasAll(['name', 'balance', 'totalTurnover', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.balance is number &&
             data.totalTurnover is number &&
             data.createdAt == request.time;
    }

    function isValidFinancialTransaction(data) {
      return data.keys().hasAll(['clientId', 'amount', 'type', 'description', 'createdAt']) &&
             data.clientId is string &&
             data.amount is number &&
             data.type in ['Payment', 'Refund', 'Order', 'Adjustment'] &&
             data.description is string &&
             data.createdAt == request.time;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'message', 'type', 'read', 'createdAt']) &&
             data.userId is string &&
             data.message is string &&
             data.read is bool &&
             data.createdAt == request.time;
    }

    // --- Collection Routes ---

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isValidProduct(incoming()) || isAdmin());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isSignedIn() && (
        (incoming().diff(existing()).affectedKeys().hasOnly([
          'status', 'updatedAt', 'customerName', 'customerPhone', 'customerEmail', 
          'totalAmount', 'totalProfit', 'clientId', 'isFinancialProcessed',
          'carModel', 'vin', 'carYear', 'engineVolume'
        ]) && incoming().updatedAt == request.time) ||
        isAdmin()
      );
      allow delete: if isAdmin();

      match /items/{itemId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (isValidOrderItem(incoming()) || isAdmin());
        allow update: if isSignedIn() && (isAdmin() || (
          isValidOrderItem(incoming()) && 
          incoming().diff(existing()).affectedKeys().hasOnly([
            'productName', 'partNumber', 'brand', 'quantity', 'costPrice', 
            'sellingPrice', 'supplier', 'status', 'updatedAt', 'deliveryTime',
            'orderDate', 'customerName', 'parentOrderId'
          ])
        ));
        allow delete: if isSignedIn();
      }
    }

    match /requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isSignedIn();
      allow delete: if isSignedIn();

      match /items/{itemId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && isValidOrderItem(incoming());
        allow delete: if isSignedIn();
      }
    }

    function isValidCar(data) {
      return data.keys().hasAll(['model']) &&
             data.model is string && data.model.size() > 0;
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidClient(incoming());
      allow delete: if isAdmin();

      match /transactions/{txId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidFinancialTransaction(incoming());
        allow write: if false;
      }

      match /cars/{carId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && isValidCar(incoming());
        allow delete: if isSignedIn();
      }
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); // System/users can create notifications
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console
    }
  }
}
